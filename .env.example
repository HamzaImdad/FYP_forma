# FORMA environment template — copy to .env and fill in real values.
# Never commit the real .env file; it is gitignored.

# ── Required ───────────────────────────────────────────────────────────
# Any random string (32+ characters) used to sign JWT auth cookies.
# Generate locally: python -c "import secrets; print(secrets.token_hex(32))"
FORMA_JWT_SECRET=replace-with-random-32+-char-string

# ── Optional: chatbot features ─────────────────────────────────────────
# Without a key, the three chatbots (personal coach, plan creator, public
# FAQ) are disabled; all other features run normally.
OPENAI_API_KEY=sk-...

# ── Optional: overrides ────────────────────────────────────────────────
# Flask session signing key. Has a dev fallback, only set for production.
# EXERVISION_SECRET_KEY=replace-with-random-string

# Override SQLite path. Default: <repo>/exervision.db
# DB_PATH=/var/data/exervision.db

# Override HTTP server port. Default: 5000
# PORT=5000
